  "target_agencies": [],

  "company_profile": {
    "name": "wellConnected",
    "platform": "allco",
    "mission": "allco is a HIPAA-compliant data-sharing platform built by wellConnected that connects healthcare organizations and community-based organizations (CBOs) so patients can be referred for services (e.g. food pantries, housing, mental health) and have their data follow them between providers without re-entering it. allco focuses on closed-loop referrals, cross-organization collaboration, and social determinants of health (SDOH) outcomes for underserved communities."
  },

  "evaluation": {
    "llm_model": "claude-sonnet-4-6",
    "min_relevance_score": 5,
    "min_days_until_deadline": 7,
    "max_days_until_deadline": 365,
    "flag_sole_source": true,
    "evaluation_prompt_template": "You are evaluating an RFP/grant opportunity for {name}, the company behind {platform}.\n\nCompany profile:\n{mission}\n\nKeyword match score (0-1, higher = more overlap): {keyword_score}\nKeyword matches by category:\n{keyword_matches_summary}\n\nOpportunity:\nTitle: {title}\nAgency/Funder: {agency_or_funder}\nDeadline: {deadline}\nEstimated Value: {estimated_value}\nDescription: {description}\n\nEvaluate how well this opportunity fits {name} and {platform}. Consider: relevance to our data-sharing and SDOH mission, geographic fit, realistic win likelihood, and any red flags such as sole-source requirements or mismatched scope."
  },

  "output": {
    "database": {
      "path": "opportunities.db"
    },
    "report": {
      "output_path": "reports/",
      "max_opportunities_per_report": 50
    }
  },

  "notifications": {
    "enabled": false
  },

  "logging": {
    "level": "INFO",
    "file": "agent.log"
  },

  "scheduler": {
    "enabled": false,
    "daily_run_time": "08:00",
    "run_on_startup": true
  },

